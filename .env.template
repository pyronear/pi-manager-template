# Path to the sister pi-manager-X repo holding inventory, host_vars and secrets
REPO_PATH=../pi-manager-X
# Vault password file and SSH private key (usually inside the sister repo)
VAULT_PASSWORD_FILE=../pi-manager-X/.vault_passwrd
SSH_PRIVATE_KEY_FILE=../pi-manager-X/id_rsa
# Default ansible --limit target for the install-servers target
LIMIT=st-peray
